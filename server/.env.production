# ==========================================
# ZYNQ — Production Environment Variables
# ==========================================

# Core
NODE_ENV=production
PORT=5000
CLIENT_URL=https://app.zynq.example.com

# Database
POSTGRES_DB=zynq_db
POSTGRES_USER=zynq_user
POSTGRES_PASSWORD=your_secure_password
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379

# Security
JWT_SECRET=generate_a_very_secure_random_string
JWT_EXPIRES_IN=24h

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# WhatsApp API (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your_phone_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_DAILY_LIMIT=1000

# Google Cloud Speech (Fallback)
GOOGLE_APPLICATION_CREDENTIALS=/app/google-service-account.json

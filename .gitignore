# ============================================================
# ZYNQ — .gitignore
# ============================================================

# ─── DEPENDENCIES ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── ENVIRONMENT VARIABLES ─────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── BUILD OUTPUT ───────────────────────────────────────────
dist/
build/
.next/
out/

# ─── LOGS ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── RUNTIME ────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ─── COVERAGE & TESTING ────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── IDE & EDITOR ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── OS FILES ───────────────────────────────────────────────
.DS_Store
ehthumbs.db

# ─── TYPESCRIPT ─────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── UPLOADS & USER DATA ───────────────────────────────────
uploads/
temp/
tmp/

# ─── SECRETS & KEYS ────────────────────────────────────────
keys/
*.pem
*.key
*.cert
*.crt

# ─── DOCKER (local volumes) ────────────────────────────────
docker-data/
pgdata/
redis-data/

# ─── MISC ───────────────────────────────────────────────────
.turbo
.vercel
.cache
.eslintcache
.prettierignore
